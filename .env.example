# Copy to .env (never commit .env). With DATABASE_URL unset, the app uses a
# local SQLite file in ./data — perfect for local development.

# Supabase / any Postgres. Get this from Supabase:
#   Project → Connect → ORMs / Connection string → "Transaction pooler" URI
#   (looks like postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres)
# DATABASE_URL=

# Key used to encrypt seller stock codes at rest (set a long random string in production)
# STOCK_ENCRYPTION_KEY=
